---
/**
 * Projects — Section présentant les projets réalisés.
 */
import { projects } from "../data/portfolio";
---

<section id="projets" class="section" aria-label="Projets">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Projets</h2>
      <p class="section-subtitle">Découvrez les projets que j'ai réalisés</p>
    </div>

    <div class="projects-grid" role="list">
      {projects.map((project) => (
        <article class="project-card" role="listitem">
          <!-- En-tête du projet -->
          <div class="project-header">
            <div class="project-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
            </div>
            <div class="project-links">
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener noreferrer" aria-label={`Voir ${project.title} sur GitHub`} class="project-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                </a>
              )}
              {project.demo && (
                <a href={project.demo} target="_blank" rel="noopener noreferrer" aria-label={`Voir la démo de ${project.title}`} class="project-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                </a>
              )}
            </div>
          </div>

          <!-- Corps du projet -->
          <h3 class="project-title">{project.title}</h3>
          <p class="project-desc">{project.description}</p>

          <!-- Technologies -->
          <ul class="project-tech" aria-label="Technologies utilisées">
            {project.technologies.map((tech) => (
              <li class="tech-tag">{tech}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: all var(--transition);
  }

  .project-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .project-icon {
    color: var(--color-primary);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
  }

  .project-link {
    color: var(--color-text-light);
    transition: color var(--transition);
  }

  .project-link:hover {
    color: var(--color-primary);
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .project-desc {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.7;
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }

  .project-tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .tech-tag {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--color-text-light);
    background: var(--color-bg-alt);
    padding: 0.25rem 0.6rem;
    border-radius: 0.25rem;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
