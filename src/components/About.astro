---
/**
 * About — Section à propos avec compétences et certifications.
 */
import { skills, certifications, personalInfo } from "../data/portfolio";
---

<section id="a-propos" class="section" aria-label="À propos">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">À propos</h2>
      <p class="section-subtitle">Compétences, certifications et centres d'intérêt</p>
    </div>

    <!-- Présentation -->
    <div class="about-intro">
      <p>
        Étudiante ingénieure à l'<strong>{personalInfo.school.split("—")[0].trim()}</strong> à {personalInfo.city}, {personalInfo.country},
        je suis passionnée par le développement logiciel et les nouvelles technologies.
        Mon objectif est de concevoir des solutions innovantes et accessibles.
      </p>
    </div>

    <!-- Compétences -->
    <div class="skills-grid" role="list" aria-label="Compétences">
      {skills.map((skillGroup) => (
        <div class="skill-card" role="listitem">
          <h3 class="skill-category">{skillGroup.category}</h3>
          <ul class="skill-list">
            {skillGroup.items.map((item) => (
              <li class="skill-tag">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    {certifications.length > 0 && (
      <div class="certifications">
        <h3 class="cert-title">Certifications & Attestations</h3>
        <div class="cert-grid">
          {certifications.map((cert) => (
            <div class="cert-card">
              <div class="cert-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <div>
                <p class="cert-name">{cert.title}</p>
                <p class="cert-issuer">{cert.issuer} · {cert.year}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .about-intro {
    max-width: 700px;
    margin: 0 auto 3rem;
    text-align: center;
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .about-intro strong {
    color: var(--color-text);
  }

  /* Grille de compétences */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .skill-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: all var(--transition);
  }

  .skill-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .skill-category {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    font-size: 0.82rem;
    font-weight: 500;
  }

  /* Certifications */
  .certifications {
    margin-top: 1rem;
  }

  .cert-title {
    text-align: center;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .cert-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .cert-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
  }

  .cert-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .cert-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .cert-issuer {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-top: 0.15rem;
  }
</style>
