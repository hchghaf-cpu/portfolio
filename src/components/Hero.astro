---
/**
 * Hero — Section d'accueil avec présentation principale.
 */
import { personalInfo } from "../data/portfolio";
---

<section id="accueil" class="hero section" aria-label="Accueil">
  <div class="container hero-content">
    <div class="hero-text">
      <p class="hero-kicker">Creative Portfolio</p>
      <h1 class="hero-name">{personalInfo.fullName}</h1>
      <p class="hero-title">{personalInfo.title}</p>
      <p class="hero-bio">{personalInfo.bio}</p>
      <div class="hero-actions">
        <a href="#projets" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          View Projects
        </a>
        <a href="#contact" class="btn btn-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Contact Me
        </a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="hero-photo-wrap">
        <img src="/hiba.png" alt={`Photo de ${personalInfo.fullName}`} class="hero-photo" width="520" height="620" />
      </div>
      <div class="hero-ornament hero-ornament-one"></div>
      <div class="hero-ornament hero-ornament-two"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 7.5rem;
    padding-bottom: 5.5rem;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero-content {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(290px, 0.95fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .hero-kicker {
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 1.1rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7.2vw, 5.45rem);
    font-weight: 700;
    line-height: 1.03;
    margin-bottom: 0.85rem;
    color: var(--color-text);
  }

  .hero-title {
    font-size: clamp(1rem, 2.2vw, 1.45rem);
    color: #1f4f4a;
    margin-bottom: 1.25rem;
    font-weight: 600;
    max-width: 36ch;
  }

  .hero-bio {
    font-size: clamp(1rem, 1.5vw, 1.14rem);
    color: var(--color-text-light);
    max-width: 52ch;
    line-height: 1.9;
    margin-bottom: 2.2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-photo-wrap {
    width: min(100%, 500px);
    border-radius: 2rem;
    padding: clamp(0.6rem, 1.2vw, 0.95rem);
    background: linear-gradient(145deg, rgba(15, 118, 110, 0.35), rgba(217, 119, 6, 0.34));
    box-shadow: var(--shadow-lg);
    position: relative;
    z-index: 1;
  }

  .hero-photo {
    width: 100%;
    height: clamp(370px, 54vw, 620px);
    object-fit: cover;
    border-radius: 1.5rem;
    border: 2px solid rgba(255, 255, 255, 0.64);
  }

  .hero-ornament {
    position: absolute;
    border-radius: 999px;
    z-index: 0;
    animation: float 7s ease-in-out infinite;
  }

  .hero-ornament-one {
    width: 150px;
    height: 150px;
    top: -1.8rem;
    right: -1.8rem;
    background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.7), rgba(217, 119, 6, 0.35));
  }

  .hero-ornament-two {
    width: 110px;
    height: 110px;
    bottom: -1.4rem;
    left: -1.25rem;
    background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.8), rgba(15, 118, 110, 0.34));
    animation-delay: 1.2s;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 6rem;
      min-height: initial;
    }

    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.8rem;
    }

    .hero-bio {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .hero-photo-wrap {
      width: min(100%, 410px);
    }

    .hero-photo {
      height: min(75vh, 520px);
    }

    .hero-ornament-one {
      width: 100px;
      height: 100px;
      top: -1rem;
      right: -0.8rem;
    }

    .hero-ornament-two {
      width: 78px;
      height: 78px;
      left: -0.4rem;
      bottom: -0.9rem;
    }
  }
</style>
