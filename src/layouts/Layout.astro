---
/**
 * Layout principal — structure HTML commune à toutes les pages.
 * Inclut le <head>, les meta, le header de navigation et le footer.
 */
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { personalInfo } from "../data/portfolio";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${personalInfo.fullName} — Portfolio`,
  description = personalInfo.bio,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={personalInfo.fullName} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      import { inject } from '@vercel/analytics';
      inject();

      // Send a push notification on each visit via ntfy.sh
      (function notifyVisit() {
        try {
          const page = window.location.pathname;
          const referrer = document.referrer || 'Direct';
          const time = new Date().toLocaleString('fr-FR', { timeZone: 'Africa/Casablanca' });
          const lang = navigator.language || 'unknown';
          const device = /Mobi|Android/i.test(navigator.userAgent) ? '📱 Mobile' : '💻 Desktop';

          fetch('https://ntfy.sh/portefolio-hiba-chghaf-visits', {
            method: 'POST',
            headers: {
              'Title': `${device} Nouveau visiteur sur ton portfolio!`,
              'Tags': 'eyes,wave',
              'Priority': '3',
            },
            body: `Page: ${page}\nRéférent: ${referrer}\nAppareil: ${device}\nLangue: ${lang}\nHeure: ${time}`,
          });
        } catch (_) { /* silently ignore errors */ }
      })();
    </script>
  </body>
</html>

<style is:global>
  /* ─── Reset & Variables CSS ─── */
  :root {
    --color-primary: #0f766e;
    --color-primary-dark: #115e59;
    --color-primary-light: #ccfbf1;
    --color-accent: #d97706;
    --color-bg: #f6f1e7;
    --color-bg-alt: #fff9ef;
    --color-bg-card: #ffffff;
    --color-text: #2c1d14;
    --color-text-light: #64594f;
    --color-border: #e8dccb;
    --color-success: #10b981;
    --font-display: "Cormorant Garamond", "Times New Roman", serif;
    --font-sans: "Manrope", "Segoe UI", system-ui, -apple-system, sans-serif;
    --font-mono: "JetBrains Mono", "Fira Code", monospace;
    --shadow-sm: 0 3px 10px rgba(44, 29, 20, 0.07);
    --shadow-md: 0 12px 26px rgba(44, 29, 20, 0.11);
    --shadow-lg: 0 26px 45px rgba(44, 29, 20, 0.16);
    --radius: 0.75rem;
    --max-width: 1160px;
    --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }

  body {
    font-family: var(--font-sans);
    color: var(--color-text);
    background-color: var(--color-bg);
    background-image:
      radial-gradient(circle at 8% 12%, rgba(15, 118, 110, 0.11), transparent 22%),
      radial-gradient(circle at 86% 20%, rgba(217, 119, 6, 0.12), transparent 24%),
      radial-gradient(circle at 70% 86%, rgba(15, 118, 110, 0.1), transparent 22%),
      linear-gradient(180deg, #f8f3ea 0%, #f6f1e7 48%, #f3ece0 100%);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition);
  }

  a:hover {
    color: var(--color-primary-dark);
  }

  /* ─── Skip link (accessibilité) ─── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius);
    z-index: 1000;
    font-weight: 600;
  }

  .skip-link:focus {
    top: 1rem;
  }

  /* ─── Utilitaires ─── */
  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section {
    padding: 5rem 0;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.6rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    position: relative;
    letter-spacing: 0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 3rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header .section-title::after {
    content: "";
    display: block;
    width: 3rem;
    height: 3px;
    background: var(--color-primary);
    margin: 0.75rem auto 0;
    border-radius: 2px;
  }

  /* ─── Boutons ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.85rem;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all var(--transition);
    text-decoration: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
    box-shadow: var(--shadow-sm);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--color-primary-dark), #b45309);
    color: #fff;
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .btn-outline {
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    background: rgba(255, 255, 255, 0.5);
  }

  .btn-outline:hover {
    background: var(--color-primary);
    color: #fff;
    transform: translateY(-3px);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .section {
      padding: 3.5rem 0;
    }

    .section-title {
      font-size: 1.65rem;
    }
  }
</style>
